<Window x:Class="MES_Link.MainUI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:local="clr-namespace:MES_Link.MainUI.ViewModels"
        ui:ThemeManager.RequestedTheme="Dark"
        mc:Ignorable="d"
        Title="MES Link" 
        Height="750" 
        Width="950"
        WindowState="Maximized">

    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Closing">
            <i:InvokeCommandAction Command="{Binding WindowClosingCommand}" />
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <Window.Resources>
        <Style x:Key="ModernIconButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="4" 
                                Padding="2">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#334155"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#475569"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type GroupBox}">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="Margin" Value="10,5,5,5"/>
            <Setter Property="Background" Value="#0F172A"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type GroupBox}">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                SnapsToDevicePixels="True">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" 
                                        Background="#1E293B" 
                                        CornerRadius="5,5,0,0" 
                                        Padding="10,8,10,8"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="0,0,0,1">
                                    <ContentPresenter ContentSource="Header" 
                                                      SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                </Border>

                                <ContentPresenter Grid.Row="1" 
                                                  Margin="{TemplateBinding Padding}" 
                                                  SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SmallButton" TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Padding" Value="5,2,5,2"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="SmallComboBox" TargetType="{x:Type ComboBox}" BasedOn="{StaticResource {x:Type ComboBox}}">
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="Height" Value="25"/>
            <Setter Property="Padding" Value="10,0,0,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style TargetType="{x:Type ListBoxItem}" BasedOn="{StaticResource {x:Type ListBoxItem}}">
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="Padding" Value="12,4,12,4"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="{x:Type TextBox}" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Padding" Value="5,2,18,18"/>
        </Style>

        <Style TargetType="{x:Type ScrollViewer}" BasedOn="{StaticResource {x:Type ScrollViewer}}">
            <Setter Property="ui:ScrollViewerHelper.AutoHideScrollBars" Value="False"/>
        </Style>
    </Window.Resources>

    <Grid Background="#0B0F19">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Background="#0F172A">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="30"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="1"
                       Margin="3"
                       Text="MES Link" 
                       FontFamily="Freestyle Script" 
                       FontWeight="Bold" 
                       FontSize="40" 
                       Foreground="#E2E8F0"
                       VerticalAlignment="Center"/>

            <Grid Grid.Column="3" Margin="0,0,20,0" VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="60"/>
                </Grid.ColumnDefinitions>

                <Ellipse Grid.Column="0" Width="16" Height="16" VerticalAlignment="Center" Margin="0,0,8,0">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Setter Property="Fill">
                                <Setter.Value>
                                    <RadialGradientBrush Center="0.5,0.5" RadiusX="0.5" RadiusY="0.5" GradientOrigin="0.5,0.5">
                                        <GradientStop Color="#FFFFFF" Offset="0.0"/>
                                        <GradientStop Color="#EF4444" Offset="0.2"/>
                                        <GradientStop Color="#F43F5E" Offset="0.5"/>
                                        <GradientStop Color="#00F43F5E" Offset="1.0"/>
                                    </RadialGradientBrush>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsServerRunning}" Value="True">
                                    <Setter Property="Fill">
                                        <Setter.Value>
                                            <RadialGradientBrush Center="0.5,0.5" RadiusX="0.5" RadiusY="0.5" GradientOrigin="0.5,0.5">
                                                <GradientStop Color="#FFFFFF" Offset="0.0"/>
                                                <GradientStop Color="#34D399" Offset="0.2"/>
                                                <GradientStop Color="#10B981" Offset="0.5"/>
                                                <GradientStop Color="#0010B981" Offset="1.0"/>
                                            </RadialGradientBrush>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>

                <TextBlock Grid.Column="1" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="OFFLINE"/>
                            <Setter Property="Foreground" Value="#94A3B8"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsServerRunning}" Value="True">
                                    <Setter Property="Text" Value="ONLINE"/>
                                    <Setter Property="Foreground" Value="#10B981"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
        </Grid>

        <Grid Grid.Row="1" >
            <GroupBox Margin="5" Grid.Column="0">
                <GroupBox.HeaderTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="{Binding DataContext.CopyRights, RelativeSource={RelativeSource AncestorType=Window}}"  
                                       Foreground="#94A3B8" 
                                       VerticalAlignment="Center" 
                                       Margin="5" 
                                       FontSize="10" 
                                       FontWeight="Bold"
                                       Grid.Column="0"/>

                            <Button Command="{Binding DataContext.ToggleServerCommand, RelativeSource={RelativeSource AncestorType=Window}}" 
                                    Content="{Binding DataContext.ServerButtonText, RelativeSource={RelativeSource AncestorType=Window}}"
                                    Grid.Column="2"
                                    Width="120"
                                    FontSize="18"
                                    Height="30"
                                    FontWeight="Bold"
                                    Foreground="White">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource SmallButton}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DataContext.IsServerRunning, RelativeSource={RelativeSource AncestorType=Window}}" Value="False">
                                                <Setter Property="Background" Value="#10B981"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding DataContext.IsServerRunning, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                                <Setter Property="Background" Value="#F43F5E"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>
                    </DataTemplate>
                </GroupBox.HeaderTemplate>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <GroupBox Grid.Column="0" Header="Editor" Margin="5">
                        <GroupBox.HeaderTemplate>
                            <DataTemplate>
                                <Grid Margin="5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="🔗URL" 
                                               Foreground="#E2E8F0" 
                                               VerticalAlignment="Center" 
                                               Margin="-5,0,0,0" 
                                               FontSize="13" 
                                               FontWeight="Bold"
                                               Grid.Column="0"/>

                                    <TextBox Text="{Binding DataContext.BaseUrlInput, RelativeSource={RelativeSource AncestorType=GroupBox}, UpdateSourceTrigger=PropertyChanged}" 
                                             IsEnabled="{Binding DataContext.IsRoutesEditable, RelativeSource={RelativeSource AncestorType=GroupBox}}"
                                             Background="#090D16" 
                                             Foreground="#F8FAFC" 
                                             Margin="2" 
                                             Width="200"
                                             MinHeight="0" 
                                             Height="24" 
                                             Padding="5,2,5,2"
                                             VerticalAlignment="Center"
                                             ui:TextBoxHelper.IsDeleteButtonVisible="False"
                                             Grid.Column="1"/>

                                    <Button Content="＋" 
                                         Width="30"
                                         Command="{Binding DataContext.AddRouteCommand, RelativeSource={RelativeSource AncestorType=GroupBox}}" 
                                         Margin="0,0,5,0"
                                         Grid.Column="3"
                                         ToolTip="Add List">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource SmallButton}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DataContext.IsServerRunning, RelativeSource={RelativeSource AncestorType=GroupBox}}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding DataContext.IsRoutesLocked, RelativeSource={RelativeSource AncestorType=GroupBox}}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>

                                    <Button Content="{Binding DataContext.GlobalLockButtonText, RelativeSource={RelativeSource AncestorType=GroupBox}}" 
                                            Command="{Binding DataContext.ToggleGlobalLockCommand, RelativeSource={RelativeSource AncestorType=GroupBox}}"
                                            Width="30"
                                            Margin="0,0,5,0"
                                            HorizontalAlignment="Right"
                                            Foreground="#E2E8F0"
                                            Grid.Column="4"
                                            ToolTip="Edit/Save">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource SmallButton}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DataContext.IsServerRunning, RelativeSource={RelativeSource AncestorType=GroupBox}}" Value="True">
                                                        <Setter Property="IsEnabled" Value="False"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </GroupBox.HeaderTemplate>

                        <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="2">
                            <ItemsControl ItemsSource="{Binding MesRoutes}" Padding="0,0,20,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#334155" 
                                                BorderThickness="1" 
                                                CornerRadius="4" 
                                                Background="#1E293B" 
                                                Margin="2,4" 
                                                Padding="8">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="20"/>
                                                    <RowDefinition Height="350"/>
                                                </Grid.RowDefinitions>

                                                <Grid Grid.Row="0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>

                                                    <TextBlock Grid.Row="0" Grid.Column="0" 
                                                               Text="🏷️ TagName" Foreground="#E2E8F0" VerticalAlignment="Center" Margin="2" FontSize="13" FontWeight="Bold"/>
                                                    <TextBox Grid.Row="0" Grid.Column="1" 
                                                             Text="{Binding TagName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                                             IsEnabled="{Binding DataContext.IsRoutesEditable, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                             ui:TextBoxHelper.IsDeleteButtonVisible="False" Background="#090D16" Foreground="#2894FF" Width="180" Margin="2" VerticalAlignment="Center" Height="24" MinHeight="0" Padding="5,2,5,2"/>

                                                    <Button Grid.Row="0" Grid.Column="4" Content="X" Foreground="White" Background="IndianRed" FontWeight="Bold" Width="25" Margin="2" VerticalAlignment="Center" ToolTip="Delete"
                                                            Command="{Binding DataContext.RemoveRouteCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" CommandParameter="{Binding}">
                                                        <Button.Style>
                                                            <Style TargetType="Button" BasedOn="{StaticResource SmallButton}">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding DataContext.IsServerRunning, RelativeSource={RelativeSource AncestorType=ItemsControl}}" Value="True">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding DataContext.IsRoutesLocked, RelativeSource={RelativeSource AncestorType=ItemsControl}}" Value="True">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                    </Button>

                                                    <TextBlock Grid.Row="1" Grid.Column="0" 
                                                               Text="📌 Route" Foreground="#E2E8F0" VerticalAlignment="Center" Margin="2" FontSize="13" FontWeight="Bold"/>
                                                    <TextBox Grid.Row="1" Grid.Column="1" 
                                                             Text="{Binding RouteUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                                             IsEnabled="{Binding DataContext.IsRoutesEditable, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                             ui:TextBoxHelper.IsDeleteButtonVisible="False" Background="#090D16" Foreground="#F8FAFC" Width="180" Margin="2" VerticalAlignment="Center" Height="24" MinHeight="0" Padding="5,2,5,2"/>

                                                    <Grid Grid.Row="1" Grid.Column="2">
                                                        <Button x:Name="CopyButton" Content="🗐" Foreground="#E2E8F0" Width="30" VerticalAlignment="Center" ToolTip="Copy Url"
                                                                Command="{Binding DataContext.CopyRouteUrlCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" CommandParameter="{Binding}">
                                                            <Button.Style>
                                                                <Style TargetType="Button" BasedOn="{StaticResource SmallButton}"/>
                                                            </Button.Style>
                                                            <Button.Triggers>
                                                                <EventTrigger RoutedEvent="Button.Click">
                                                                    <BeginStoryboard>
                                                                        <Storyboard>
                                                                            <BooleanAnimationUsingKeyFrames Storyboard.TargetName="CopiedPopup" Storyboard.TargetProperty="IsOpen">
                                                                                <DiscreteBooleanKeyFrame KeyTime="0:0:0" Value="True"/>
                                                                                <DiscreteBooleanKeyFrame KeyTime="0:0:0.5" Value="False"/>
                                                                            </BooleanAnimationUsingKeyFrames>
                                                                        </Storyboard>
                                                                    </BeginStoryboard>
                                                                </EventTrigger>
                                                            </Button.Triggers>
                                                        </Button>
                                                        <Popup x:Name="CopiedPopup" PlacementTarget="{Binding ElementName=CopyButton}" Placement="Top" VerticalOffset="-5" AllowsTransparency="True" StaysOpen="False">
                                                            <Border Background="#334155" CornerRadius="4" Padding="6,3">
                                                                <TextBlock Text="Copied!" Foreground="#F8FAFC" FontSize="11" VerticalAlignment="Center"/>
                                                            </Border>
                                                        </Popup>
                                                    </Grid>

                                                    <TextBlock Grid.Row="2" Grid.Column="0"
                                                               Text="🗃️ ContentType" Foreground="#E2E8F0" VerticalAlignment="Center" Margin="2" FontSize="13" FontWeight="Bold"/>
                                                    <ComboBox Grid.Row="2" Grid.Column="1" Width="170" Margin="2" VerticalAlignment="Center" Style="{StaticResource SmallComboBox}"
                                                              ItemsSource="{Binding DataContext.ContentTypesItem, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                              SelectedValue="{Binding ContentType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                              IsEnabled="{Binding DataContext.IsRoutesEditable, RelativeSource={RelativeSource AncestorType=ItemsControl}}"/>

                                                    <TextBlock Grid.Row="3" Grid.Column="0" 
                                                               Text="⏱️ DelayTime" Foreground="#E2E8F0" VerticalAlignment="Center" Margin="2" FontSize="13" FontWeight="Bold"/>
                                                    <ComboBox Grid.Row="3" Grid.Column="1" Width="70" Margin="2" VerticalAlignment="Center" Style="{StaticResource SmallComboBox}"
                                                              ItemsSource="{Binding DataContext.DelayMsItem, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                              SelectedValue="{Binding DelayMs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                              IsEnabled="{Binding DataContext.IsRoutesEditable, RelativeSource={RelativeSource AncestorType=ItemsControl}}"/>
                                                </Grid>

                                                <Grid Grid.Row="2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="*"/>
                                                    </Grid.RowDefinitions>

                                                    <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Margin="0,0,5,5">
                                                        <RadioButton Content="Format Ⅰ" GroupName="{Binding GetHashCode}" Foreground="#34D399" VerticalAlignment="Center" FontWeight="SemiBold" Cursor="Hand"
                                                                     IsChecked="{Binding IsSelected_Format1, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                        <ComboBox Width="70" VerticalAlignment="Center" Style="{StaticResource SmallComboBox}"
                                                                  ItemsSource="{Binding DataContext.StatusCodesItem, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                  SelectedValue="{Binding StatusCode_Format1, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                  IsEnabled="{Binding DataContext.IsRoutesEditable, RelativeSource={RelativeSource AncestorType=ItemsControl}}"/>
                                                    </StackPanel>

                                                    <Border Grid.Row="1" Grid.Column="0" Margin="0,0,5,0" BorderThickness="2" CornerRadius="3">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="BorderBrush" Value="Transparent"/>
                                                                <Setter Property="Opacity" Value="0.8"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsSelected_Format1}" Value="True">
                                                                        <Setter Property="BorderBrush" Value="#10B981"/>
                                                                        <Setter Property="Opacity" Value="1.0"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBox Text="{Binding Format1, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                 IsEnabled="{Binding DataContext.IsRoutesEditable, RelativeSource={RelativeSource AncestorType=ItemsControl}}" 
                                                                 AcceptsReturn="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                                                 ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                                 FontFamily="Consolas" FontSize="13" Background="#090D16" Foreground="#FEF08A"/>
                                                    </Border>

                                                    <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="5,0,0,5">
                                                        <RadioButton Content="Format Ⅱ" GroupName="{Binding GetHashCode}" Foreground="#F87171" VerticalAlignment="Center" FontWeight="SemiBold" Cursor="Hand"
                                                                     IsChecked="{Binding IsSelected_Format2, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                        <ComboBox Width="70" VerticalAlignment="Center" Style="{StaticResource SmallComboBox}"
                                                                  ItemsSource="{Binding DataContext.StatusCodesItem, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                  SelectedValue="{Binding StatusCode_Format2, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                  IsEnabled="{Binding DataContext.IsRoutesEditable, RelativeSource={RelativeSource AncestorType=ItemsControl}}"/>
                                                    </StackPanel>

                                                    <Border Grid.Row="1" Grid.Column="1" Margin="5,0,0,0" BorderThickness="2" CornerRadius="3">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="BorderBrush" Value="Transparent"/>
                                                                <Setter Property="Opacity" Value="0.8"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsSelected_Format2}" Value="True">
                                                                        <Setter Property="BorderBrush" Value="#F43F5E"/>
                                                                        <Setter Property="Opacity" Value="1.0"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBox Text="{Binding Format2, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                 IsEnabled="{Binding DataContext.IsRoutesEditable, RelativeSource={RelativeSource AncestorType=ItemsControl}}" 
                                                                 AcceptsReturn="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                                                 ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                                 FontFamily="Consolas" FontSize="13" Background="#090D16" Foreground="#FCE7F3"/>
                                                    </Border>
                                                </Grid>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </GroupBox>

                    <GroupBox Grid.Column="1" Header="Log View" Margin="5">
                        <GroupBox.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" Foreground="#E2E8F0" FontSize="12"/>
                            </DataTemplate>
                        </GroupBox.HeaderTemplate>

                        <TextBox Text="{Binding SimulatorLog, Mode=OneWay}" 
                                 FontFamily="Consolas" 
                                 FontSize="14" 
                                 IsReadOnly="True" 
                                 AcceptsReturn="True"
                                 Background="#090D16" 
                                 Foreground="#34D399"
                                 VerticalScrollBarVisibility="Auto" 
                                 HorizontalScrollBarVisibility="Auto"
                                 TextChanged="LogView_TextChanged"/>
                    </GroupBox>
                </Grid>
            </GroupBox>
        </Grid>
    </Grid>
</Window>